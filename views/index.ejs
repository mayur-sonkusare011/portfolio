    <style>
        :root {
            --primary: #00e1ff;
            --secondary: #1e293b;
            --accent: #00ff88;
            --text: #f8fafc;
            --dark: #070914;
            --neon-blue: #00e1ff;
            --neon-pink: #00ff88;
            /* Replaced pink with biological green */
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--dark);
            color: var(--text);
            overflow-x: hidden;
        }

        .section {
            min-height: 100vh;
            width: 100%;
            display: flex;
            align-items: center;
            padding: 5rem 2rem;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            width: 100%;
        }

        .btn {
            display: inline-block;
            padding: 0.8rem 1.8rem;
            border-radius: 0.5rem;
            font-weight: 600;
            transition: all 0.3s ease;
            text-decoration: none;
            position: relative;
            overflow: hidden;
            z-index: 1;
        }

        .btn-primary {
            background: var(--primary);
            color: white;
            border: 2px solid var(--primary);
        }

        .btn-primary:hover {
            background: transparent;
            color: var(--primary);
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(16, 185, 129, 0.3);
        }

        .btn-outline {
            background: transparent;
            color: var(--primary);
            border: 2px solid var(--primary);
        }

        .btn-outline:hover {
            background: var(--primary);
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(16, 185, 129, 0.3);
        }

        .section-title {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 1rem;
            position: relative;
            display: inline-block;
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 0;
            width: 60px;
            height: 4px;
            background: var(--primary);
            border-radius: 2px;
        }

        .card {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(10px);
            border-radius: 1rem;
            padding: 2rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
        }

        .card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
            border-color: var(--primary);
        }

        .skill-bar {
            height: 8px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 4px;
            margin: 1rem 0;
            overflow: hidden;
        }

        .skill-progress {
            height: 100%;
            background: var(--primary);
            border-radius: 4px;
            position: relative;
        }

        .floating {
            animation: floating 4s ease-in-out infinite;
        }

        @keyframes floating {
            0% {
                transform: translate(0, 0px);
                box-shadow: 0 0 15px rgba(0, 255, 136, 0.2);
            }

            50% {
                transform: translate(0, -12px);
                box-shadow: 0 0 35px rgba(0, 255, 136, 0.8);
            }

            100% {
                transform: translate(0, 0px);
                box-shadow: 0 0 15px rgba(0, 255, 136, 0.2);
            }
        }

        .nav-link {
            position: relative;
            padding: 0.5rem 1rem;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .nav-link::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            width: 0;
            height: 2px;
            background: var(--primary);
            transition: all 0.3s ease;
            transform: translateX(-50%);
        }

        .nav-link:hover::after {
            width: 100%;
        }

        .project-card {
            position: relative;
            overflow: hidden;
            border-radius: 1rem;
            height: 300px;
        }

        .project-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(15, 23, 42, 0.9);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 2rem;
            opacity: 0;
            transition: all 0.3s ease;
        }

        .project-card:hover .project-overlay {
            opacity: 1;
        }

        .timeline-item {
            position: relative;
            padding-left: 2rem;
            margin-bottom: 3rem;
        }

        .timeline-item::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            width: 2px;
            height: 100%;
            background: var(--primary);
        }

        .timeline-item::after {
            content: '';
            position: absolute;
            left: -4px;
            top: 0;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: var(--primary);
        }

        .contact-input {
            width: 100%;
            padding: 1rem;
            background: rgba(30, 41, 59, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 0.5rem;
            color: white;
            margin-bottom: 1.5rem;
            transition: all 0.3s ease;
        }

        .contact-input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.2);
        }

        .notification {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 1rem 2rem;
            border-radius: 0.5rem;
            z-index: 1000;
            transform: translateX(150%);
            transition: transform 0.5s ease;
        }

        .notification.show {
            transform: translateX(0);
        }

        .notification.success {
            background: #10b981;
        }

        .notification.error {
            background: #ef4444;
        }

        .skill-tag {
            display: inline-block;
            padding: 0.4rem 1rem;
            background: rgba(16, 185, 129, 0.2);
            color: var(--primary);
            border-radius: 2rem;
            margin: 0.25rem;
            font-size: 0.875rem;
            border: 1px solid rgba(16, 185, 129, 0.3);
        }

        .publication-item {
            border-left: 3px solid var(--primary);
            padding-left: 1.5rem;
            margin-bottom: 2rem;
        }

        .certificate-link {
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .certificate-link:hover {
            color: #34d399;
            transform: translateY(-2px);
        }

        .social-link {
            transition: all 0.3s ease;
        }

        .social-link:hover {
            transform: translateY(-3px);
        }

        /* Multiple Floating DNA Animations */
        .dna-bg {
            position: absolute;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 15px;
            z-index: 0;
            opacity: 0.6;
            animation: floatAround 20s infinite ease-in-out alternate;
        }

        .dna-strand {
            position: relative;
            width: 80px;
            height: 2px;
            background: rgba(255, 255, 255, 0.3);
            transform-style: preserve-3d;
            animation: spinDNA 4s linear infinite;
        }

        .dna-strand::before,
        .dna-strand::after {
            content: '';
            position: absolute;
            top: -6px;
            width: 14px;
            height: 14px;
            border-radius: 50%;
        }

        .dna-strand::before {
            left: 0;
            background: var(--neon-blue);
            box-shadow: 0 0 15px var(--neon-blue), inset 0 0 4px white;
        }

        .dna-strand::after {
            right: 0;
            background: var(--neon-pink);
            box-shadow: 0 0 15px var(--neon-pink), inset 0 0 4px white;
        }

        @keyframes spinDNA {
            0% {
                transform: rotateY(0deg);
            }

            100% {
                transform: rotateY(360deg);
            }
        }

        @keyframes floatAround {
            0% {
                transform: translate(0, 0) rotate(25deg);
            }

            50% {
                transform: translate(30px, -50px) rotate(15deg);
            }

            100% {
                transform: translate(-20px, 40px) rotate(35deg);
            }
        }
    </style>
</head>

